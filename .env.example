# API Key para Google Gemini (server-side únicamente — sin prefijo VITE_)
# La clave la usa exclusivamente la Netlify Function netlify/functions/gemini.ts
# Configurala en: Netlify → Site settings → Environment variables
# Obtené tu clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_gemini_api_key_aqui
